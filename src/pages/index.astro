---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import burgerPoster from '../assets/Image2.png';
import burgerVideo from '../assets/burger-assembly.mp4';
---

<Layout>
  <main class="burger-page" style={`--burger-poster: url("${burgerPoster.src}")`}>
    <section class="hero-burger" aria-labelledby="hero-title">
      <video
        class="hero-video"
        data-hero-video
        autoplay
        muted
        loop
        playsinline
        webkit-playsinline
        x5-playsinline
        x5-video-player-type="h5"
        preload="auto"
        poster={burgerPoster.src}
        aria-hidden="true"
      >
        <source src={burgerVideo} type="video/mp4" />
      </video>

      <div class="video-fallback" aria-hidden="true"></div>

      <div class="fire-atmosphere" aria-hidden="true">
        <span class="flare flare-1"></span>
        <span class="flare flare-2"></span>
        <span class="spark spark-1"></span>
        <span class="spark spark-2"></span>
        <span class="spark spark-3"></span>
        <span class="spark spark-4"></span>
      </div>

      <div class="smoke-layer smoke-back" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </div>

      <div class="hero-copy">
        <p class="eyebrow">Smash burgers al fuego</p>
        <h1 id="hero-title">LA BRASA <span>GAMBERRA</span></h1>
        <div class="hero-actions">
          <a href="/takeaway">Pedir ahora</a>
          <a href="/carta">Ver carta</a>
        </div>
      </div>

      <div class="hero-stats" aria-label="Datos destacados">
        <div>
          <strong>180g</strong>
          <span>Smash</span>
        </div>
        <div>
          <strong>00:30</strong>
          <span>Cierre</span>
        </div>
        <div>
          <strong>100%</strong>
          <span>Brasa</span>
        </div>
      </div>

      <div class="smoke-layer smoke-front" aria-hidden="true">
        <span></span>
        <span></span>
      </div>
    </section>

    <section class="ticker-strip" aria-hidden="true">
      <div class="ticker-track">
        <span>BRASA NIGHT</span>
        <span>SMASH BURGERS</span>
        <span>CHEDDAR FUNDIDO</span>
        <span>BACON CRUJIENTE</span>
        <span>PIDE ONLINE</span>
        <span>BRASA NIGHT</span>
        <span>SMASH BURGERS</span>
        <span>CHEDDAR FUNDIDO</span>
        <span>BACON CRUJIENTE</span>
        <span>PIDE ONLINE</span>
      </div>
    </section>

    <section class="menu-teaser" aria-labelledby="menu-title">
      <div class="menu-inner">
        <div class="section-kicker">Cartelera principal</div>
        <h2 id="menu-title">Burgers con mala idea y producto serio</h2>

        <div class="burger-grid">
          <article class="burger-card">
            <span class="burger-number">01</span>
            <h3>La Gamberra</h3>
            <p>Doble smash, cheddar fundido, bacon crujiente, cebolla roja y salsa de la casa.</p>
            <strong>Combate estrella · 12,90</strong>
          </article>

          <article class="burger-card featured">
            <span class="burger-number">02</span>
            <h3>La Brasa</h3>
            <p>Carne marcada al fuego, queso americano, pepinillos, tomate fresco y pan brioche tostado.</p>
            <strong>Main event · 13,90</strong>
          </article>

          <article class="burger-card">
            <span class="burger-number">03</span>
            <h3>La Salvaje</h3>
            <p>Triple smash, cheddar extra, bacon ahumado, salsa picante y golpe de carbon.</p>
            <strong>Sin reglas · 15,50</strong>
          </article>
        </div>

        <div class="menu-actions">
          <a href="/carta">Ver carta</a>
          <a href="/takeaway">Pedir online</a>
        </div>
      </div>
    </section>

    <section class="fire-story" aria-labelledby="story-title">
      <div class="story-media" aria-hidden="true"></div>
      <div class="story-copy">
        <div class="section-kicker">Fuego, grasa y descaro</div>
        <h2 id="story-title">No venimos a hacer burgers correctas</h2>
        <p>
          Smash marcado al momento, pan brioche tostado, queso cayendo y una brasa que se nota antes de morder.
          Esto va de producto serio con actitud gamberra.
        </p>

        <div class="proof-row">
          <span>Carne 100% vacuno</span>
          <span>Pan brioche tostado</span>
          <span>Salsas propias</span>
        </div>
      </div>
    </section>

    <section class="order-band" aria-labelledby="order-title">
      <div>
        <div class="section-kicker">Hoy se pide fuerte</div>
        <h2 id="order-title">Reserva mesa o revienta el takeaway</h2>
      </div>

      <div class="order-panel">
        <div>
          <span>Horario</span>
          <strong>Jue-Dom · 20:00-00:30</strong>
        </div>
        <div>
          <span>Servicio</span>
          <strong>Local · Recogida · Delivery</strong>
        </div>
        <div>
          <span>Zona</span>
          <strong>Tu barrio, tu brasa</strong>
        </div>
      </div>

      <div class="menu-actions order-actions">
        <a href="/takeaway">Pedir ahora</a>
        <a href="/contacto">Contacto</a>
      </div>
    </section>

    <section class="contact-strip" aria-label="Contacto rapido">
      <p>La Brasa Gamberra</p>
      <a href="tel:+34000000000">+34 000 000 000</a>
      <a href="mailto:hola@labrasagamberra.com">hola@labrasagamberra.com</a>
      <span>Calle Brasa 13 · Jerez de la Frontera</span>
    </section>
  </main>
</Layout>

<script>
  const heroVideo = document.querySelector('[data-hero-video]');

  function startHeroVideo() {
    if (!(heroVideo instanceof HTMLVideoElement)) return;

    heroVideo.muted = true;
    heroVideo.defaultMuted = true;
    heroVideo.autoplay = true;
    heroVideo.loop = true;
    heroVideo.playsInline = true;
    heroVideo.setAttribute('muted', '');
    heroVideo.setAttribute('autoplay', '');
    heroVideo.setAttribute('playsinline', '');
    heroVideo.setAttribute('webkit-playsinline', '');
    heroVideo.setAttribute('x5-playsinline', '');
    heroVideo.setAttribute('x5-video-player-type', 'h5');

    const playAttempt = heroVideo.play();
    if (playAttempt) playAttempt.catch(() => {});
  }

  startHeroVideo();
  heroVideo?.addEventListener('loadedmetadata', startHeroVideo);
  heroVideo?.addEventListener('loadeddata', startHeroVideo);
  heroVideo?.addEventListener('canplay', startHeroVideo);
  window.addEventListener('pageshow', startHeroVideo);
  window.addEventListener('focus', startHeroVideo);
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden) startHeroVideo();
  });
</script>

<style>
  .burger-page {
    min-height: 180vh;
    overflow-x: hidden;
    background: #050403;
    color: #fff;
    isolation: isolate;
  }

  .hero-burger {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    display: grid;
    place-items: center;
    padding: clamp(5.5rem, 9vh, 7rem) 1rem 3rem;
  }

  .hero-video,
  .video-fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-video {
    z-index: -5;
    filter: saturate(1.12) contrast(1.08);
  }

  .video-fallback {
    z-index: -6;
    background-image: var(--burger-poster);
    background-position: center;
    background-size: cover;
  }

  .hero-burger::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -3;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.82), transparent 28%, transparent 68%, rgba(0, 0, 0, 0.82)),
      linear-gradient(180deg, rgba(0, 0, 0, 0.42), transparent 24%, rgba(0, 0, 0, 0.58)),
      radial-gradient(circle at 50% 48%, transparent 0 22rem, rgba(0, 0, 0, 0.24) 36rem);
    pointer-events: none;
  }

  .hero-burger::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.028) 1px, transparent 1px);
    background-size: 74px 74px;
    opacity: 0.22;
    mask-image: radial-gradient(circle at 50% 50%, black, transparent 74%);
    pointer-events: none;
  }

  .hero-copy {
    position: relative;
    z-index: 8;
    width: min(94vw, 1080px);
    margin-top: clamp(-16rem, -18vh, -8rem);
    text-align: center;
  }

  .eyebrow {
    margin: 0 0 0.45rem;
    color: #ffbc62;
    font-size: clamp(0.75rem, 1.25vw, 0.95rem);
    font-weight: 950;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-shadow: 0 0 24px rgba(0, 0, 0, 0.95);
  }

  .hero-copy h1 {
    margin: 0;
    font-size: clamp(3rem, 8.9vw, 9rem);
    font-weight: 1000;
    line-height: 0.84;
    letter-spacing: 0;
    text-transform: uppercase;
    text-shadow: 0 0 32px rgba(0, 0, 0, 0.98), 0 7px 0 rgba(0, 0, 0, 0.58);
  }

  .hero-copy h1 span {
    display: block;
    color: #ff9d25;
    text-shadow: 0 0 34px rgba(255, 91, 17, 0.78), 0 7px 0 rgba(0, 0, 0, 0.54);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.25rem;
  }

  .hero-actions a {
    display: inline-flex;
    min-height: 3.15rem;
    align-items: center;
    justify-content: center;
    padding: 0 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 8px;
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 1rem 2.5rem rgba(0, 0, 0, 0.4);
    font-size: 0.84rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    backdrop-filter: blur(10px);
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .hero-actions a:first-child {
    border-color: rgba(255, 157, 37, 0.64);
    background: #ff9d25;
    color: #140b04;
  }

  .hero-actions a:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 188, 98, 0.76);
  }

  .hero-stats {
    position: absolute;
    right: clamp(1rem, 4vw, 4rem);
    bottom: clamp(1.2rem, 5vh, 3.5rem);
    z-index: 8;
    display: grid;
    grid-template-columns: repeat(3, minmax(5rem, 1fr));
    width: min(29rem, calc(100% - 2rem));
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 8px;
    background: rgba(5, 4, 3, 0.52);
    box-shadow: 0 1.5rem 3rem rgba(0, 0, 0, 0.38);
    backdrop-filter: blur(16px);
  }

  .hero-stats div {
    display: grid;
    gap: 0.1rem;
    padding: 1rem;
    border-left: 1px solid rgba(255, 255, 255, 0.1);
  }

  .hero-stats div:first-child {
    border-left: 0;
  }

  .hero-stats strong {
    color: #ffbc62;
    font-size: clamp(1.25rem, 2.2vw, 2.2rem);
    font-weight: 1000;
    line-height: 1;
  }

  .hero-stats span {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.7rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .fire-atmosphere {
    position: absolute;
    inset: 0;
    z-index: 3;
    overflow: hidden;
    pointer-events: none;
  }

  .flare {
    position: absolute;
    bottom: 5%;
    width: 18rem;
    height: 18rem;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 96, 18, 0.34), rgba(255, 96, 18, 0.1) 42%, transparent 70%);
    filter: blur(18px);
    opacity: 0.55;
    animation: flare-pulse 4.2s ease-in-out infinite;
  }

  .flare-1 {
    left: 31%;
  }

  .flare-2 {
    right: 22%;
    animation-delay: -1.8s;
  }

  .spark {
    position: absolute;
    bottom: 16%;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #ffbd58;
    box-shadow: 0 0 18px 5px rgba(255, 90, 18, 0.74);
    animation: spark-fly 4.5s linear infinite;
  }

  .spark-1 { left: 26%; animation-delay: -0.4s; }
  .spark-2 { left: 42%; animation-delay: -2s; }
  .spark-3 { right: 34%; animation-delay: -1.3s; }
  .spark-4 { right: 20%; animation-delay: -3.1s; }

  .smoke-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .smoke-back {
    z-index: 2;
    opacity: 0.58;
  }

  .smoke-front {
    z-index: 7;
    opacity: 0.42;
    mix-blend-mode: screen;
  }

  .smoke-layer span {
    position: absolute;
    bottom: 4%;
    width: clamp(15rem, 24vw, 30rem);
    height: clamp(20rem, 34vw, 40rem);
    border-radius: 48% 52% 54% 46%;
    background:
      radial-gradient(ellipse at 35% 24%, rgba(255, 255, 255, 0.34), transparent 35%),
      radial-gradient(ellipse at 65% 58%, rgba(255, 255, 255, 0.2), transparent 44%),
      radial-gradient(ellipse at 46% 78%, rgba(165, 180, 195, 0.14), transparent 48%);
    filter: blur(20px);
    opacity: 0;
    animation: smoke-rise 8s ease-in-out infinite;
  }

  .smoke-layer span:nth-child(1) {
    left: 18%;
    animation-delay: -0.6s;
  }

  .smoke-layer span:nth-child(2) {
    left: 43%;
    animation-delay: -3.1s;
  }

  .smoke-layer span:nth-child(3) {
    right: 16%;
    animation-delay: -5.4s;
  }

  .ticker-strip {
    position: relative;
    z-index: 5;
    overflow: hidden;
    border-top: 1px solid rgba(255, 157, 37, 0.42);
    border-bottom: 1px solid rgba(255, 157, 37, 0.42);
    background: #ff9d25;
    color: #140b04;
    transform: rotate(-1deg) scale(1.02);
    transform-origin: center;
  }

  .ticker-track {
    display: flex;
    width: max-content;
    gap: 2rem;
    padding: 0.72rem 0;
    animation: ticker-move 24s linear infinite;
  }

  .ticker-track span {
    white-space: nowrap;
    font-size: clamp(0.9rem, 1.6vw, 1.35rem);
    font-weight: 1000;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ticker-track span::after {
    content: "/";
    margin-left: 2rem;
    opacity: 0.42;
  }

  .menu-teaser {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    padding: clamp(5rem, 9vw, 8rem) 1.25rem;
    background:
      linear-gradient(180deg, rgba(5, 4, 3, 0.55), #050403 28%),
      radial-gradient(circle at 50% 0%, rgba(255, 102, 25, 0.28), transparent 24rem),
      radial-gradient(circle at 12% 72%, rgba(255, 174, 72, 0.12), transparent 18rem),
      radial-gradient(circle at 88% 60%, rgba(224, 42, 22, 0.14), transparent 20rem),
      #050403;
  }

  .menu-teaser::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: var(--burger-poster);
    background-position: center top;
    background-size: cover;
    opacity: 0.12;
    filter: blur(2px) saturate(0.9);
    mask-image: linear-gradient(180deg, transparent, black 18%, transparent 78%);
  }

  .menu-teaser::after {
    content: "";
    position: absolute;
    left: -10%;
    right: -10%;
    top: -1px;
    height: 10rem;
    background: linear-gradient(180deg, #050403, rgba(5, 4, 3, 0));
    pointer-events: none;
  }

  .menu-inner {
    position: relative;
    z-index: 1;
    width: min(1180px, 100%);
    margin: 0 auto;
  }

  .section-kicker {
    margin-bottom: 0.85rem;
    color: #ffbc62;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .menu-inner h2 {
    max-width: 980px;
    margin: 0;
    font-size: clamp(2.5rem, 6vw, 6.6rem);
    font-weight: 1000;
    line-height: 0.9;
    letter-spacing: 0;
    text-transform: uppercase;
    text-shadow: 0 0 30px rgba(0, 0, 0, 0.72);
  }

  .burger-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: clamp(2rem, 5vw, 4rem);
  }

  .burger-card {
    position: relative;
    min-height: 18rem;
    padding: 1.35rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.035)),
      rgba(13, 11, 9, 0.74);
    box-shadow: 0 1.5rem 3rem rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(14px);
    transition: transform 220ms ease, border-color 220ms ease, background 220ms ease;
  }

  .burger-card:hover {
    transform: translateY(-0.45rem);
    border-color: rgba(255, 188, 98, 0.48);
  }

  .burger-card::before {
    content: "";
    position: absolute;
    inset: auto -20% -35% -20%;
    height: 12rem;
    background: radial-gradient(ellipse at center, rgba(255, 111, 25, 0.26), transparent 62%);
  }

  .burger-card.featured {
    border-color: rgba(255, 158, 43, 0.46);
    background:
      linear-gradient(180deg, rgba(255, 151, 39, 0.18), rgba(255, 255, 255, 0.045)),
      rgba(18, 13, 10, 0.82);
    transform: translateY(-1.2rem);
  }

  .burger-card.featured:hover {
    transform: translateY(-1.65rem);
  }

  .burger-number {
    color: rgba(255, 188, 98, 0.64);
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.16em;
  }

  .burger-card h3 {
    margin: 4.5rem 0 0.75rem;
    font-size: clamp(1.75rem, 3vw, 3rem);
    font-weight: 1000;
    line-height: 0.92;
    text-transform: uppercase;
  }

  .burger-card p {
    max-width: 26rem;
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .burger-card strong {
    display: block;
    margin-top: 1.25rem;
    color: #ffbc62;
    font-size: 0.88rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .menu-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 2rem;
  }

  .menu-actions a {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    padding: 0 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 8px;
    color: #fff;
    background: rgba(255, 255, 255, 0.07);
    font-size: 0.86rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .menu-actions a:first-child {
    border-color: rgba(255, 157, 37, 0.56);
    background: #ff9d25;
    color: #150b04;
  }

  .menu-actions a:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 188, 98, 0.72);
  }

  .fire-story {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(1.25rem, 5vw, 4rem);
    align-items: center;
    width: min(1180px, calc(100% - 2.5rem));
    min-height: 86vh;
    margin: 0 auto;
    padding: clamp(4rem, 8vw, 7rem) 0;
  }

  .story-media {
    min-height: clamp(23rem, 46vw, 39rem);
    border-radius: 8px;
    background-image:
      linear-gradient(180deg, rgba(0, 0, 0, 0.08), rgba(0, 0, 0, 0.46)),
      var(--burger-poster);
    background-position: center;
    background-size: cover;
    box-shadow: 0 2rem 5rem rgba(0, 0, 0, 0.5);
    clip-path: polygon(0 8%, 100% 0, 94% 100%, 5% 92%);
  }

  .story-copy h2,
  .order-band h2 {
    margin: 0;
    font-size: clamp(2.4rem, 5.7vw, 6rem);
    font-weight: 1000;
    line-height: 0.9;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .story-copy p {
    max-width: 38rem;
    margin: 1.25rem 0 0;
    color: rgba(255, 255, 255, 0.72);
    font-size: clamp(1rem, 1.7vw, 1.22rem);
    line-height: 1.65;
  }

  .proof-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1.6rem;
  }

  .proof-row span {
    padding: 0.7rem 0.85rem;
    border: 1px solid rgba(255, 188, 98, 0.22);
    border-radius: 999px;
    color: #ffbc62;
    background: rgba(255, 255, 255, 0.055);
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .order-band {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(20rem, 0.8fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: end;
    width: min(1180px, calc(100% - 2.5rem));
    margin: 0 auto clamp(3rem, 6vw, 5rem);
    padding: clamp(2rem, 5vw, 4rem);
    overflow: hidden;
    border: 1px solid rgba(255, 157, 37, 0.28);
    border-radius: 8px;
    background:
      radial-gradient(circle at 16% 22%, rgba(255, 157, 37, 0.22), transparent 22rem),
      linear-gradient(135deg, rgba(255, 255, 255, 0.09), rgba(255, 255, 255, 0.03)),
      #110c08;
    box-shadow: 0 2rem 5rem rgba(0, 0, 0, 0.42);
  }

  .order-panel {
    display: grid;
    gap: 0.8rem;
  }

  .order-panel div {
    display: grid;
