---
import Layout from '../layouts/Layout.astro';
import PageFrame from '../components/PageFrame.astro';
import { formatPrice, menuItems } from '../data/menu';

const orderableItems = menuItems.filter((item) => item.category !== 'extras');
const extras = menuItems.filter((item) => item.category === 'extras');
---

<Layout>
  <PageFrame
    kicker="Pedidos online"
    title="Takeaway con actitud"
    description="Flujo planteado para carrito, checkout, base de datos, estados de cocina y pago. Ahora funciona como prototipo local."
  >
    <section class="content-section takeaway-layout">
      <div class="order-catalog">
        <h2 class="section-title">Elige tu golpe</h2>

        <div class="order-list" data-order-list>
          {
            orderableItems.map((item) => (
              <article class="order-item">
                <div>
                  <span>{item.badge}</span>
                  <h3>{item.name}</h3>
                  <p>{item.description}</p>
                  <small>{item.tags.join(' · ')}</small>
                </div>
                <div class="order-item-action">
                  <strong>{formatPrice(item.price)}</strong>
                  <button
                    type="button"
                    data-add-item
                    data-id={item.id}
                    data-name={item.name}
                    data-price={item.price}
                  >
                    Añadir
                  </button>
                </div>
              </article>
            ))
          }
        </div>

        <h2 class="section-title extras-title">Extras</h2>
        <div class="order-list compact">
          {
            extras.map((item) => (
              <article class="order-item">
                <div>
                  <span>{item.badge}</span>
                  <h3>{item.name}</h3>
                  <p>{item.description}</p>
                </div>
                <div class="order-item-action">
                  <strong>{formatPrice(item.price)}</strong>
                  <button
                    type="button"
                    data-add-item
                    data-id={item.id}
                    data-name={item.name}
                    data-price={item.price}
                  >
                    Añadir
                  </button>
                </div>
              </article>
            ))
          }
        </div>
      </div>

      <aside class="cart-panel" aria-label="Carrito de pedido">
        <div class="cart-head">
          <span>Pedido local</span>
          <strong data-cart-total>0,00 €</strong>
        </div>

        <div class="cart-items" data-cart-items>
          <p class="empty-cart">Todavía no hay fuego en la cesta.</p>
        </div>

        <form class="checkout-form" data-checkout-form>
          <label>
            Nombre
            <input name="name" autocomplete="name" placeholder="Tu nombre" required />
          </label>
          <label>
            Teléfono
            <input name="phone" autocomplete="tel" placeholder="+34 ..." required />
          </label>
          <label>
            Servicio
            <select name="service">
              <option value="pickup">Recogida en local</option>
              <option value="delivery">Delivery</option>
            </select>
          </label>
          <label>
            Hora
            <input name="time" type="time" />
          </label>
          <label class="full">
            Notas
            <textarea name="notes" rows="3" placeholder="Sin cebolla, punto de carne, portal..."></textarea>
          </label>

          <button type="submit" data-submit-order>Enviar comanda</button>
          <small data-order-status>Servidor local listo: al enviar, la comanda entra en /admin/pedidos.</small>
        </form>
      </aside>
    </section>
  </PageFrame>
</Layout>

<script>
  const STORAGE_KEY = 'brasa-cart-v1';
  const cartItemsNode = document.querySelector('[data-cart-items]');
  const cartTotalNode = document.querySelector('[data-cart-total]');
  const checkoutForm = document.querySelector('[data-checkout-form]');
  const orderStatus = document.querySelector('[data-order-status]');
  const submitOrderButton = document.querySelector('[data-submit-order]');
  const addButtons = document.querySelectorAll('[data-add-item]');

  /** @type {Array<{id: string; name: string; price: number; quantity: number}>} */
  let cart = [];

  function formatMoney(value) {
    return new Intl.NumberFormat('es-ES', {
      style: 'currency',
      currency: 'EUR',
    }).format(value);
  }

  function loadCart() {
    try {
      cart = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
    } catch {
      cart = [];
    }
  }

  function saveCart() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(cart));
  }

  function renderCart() {
    if (!cartItemsNode || !cartTotalNode) return;

    if (!cart.length) {
      cartItemsNode.innerHTML = '<p class="empty-cart">Todavía no hay fuego en la cesta.</p>';
      cartTotalNode.textContent = formatMoney(0);
      return;
    }

    cartItemsNode.innerHTML = cart
      .map(
        (item) => `
          <div class="cart-line">
            <div>
              <strong>${item.name}</strong>
              <span>${item.quantity} x ${formatMoney(item.price)}</span>
            </div>
            <div class="cart-controls">
              <button type="button" data-dec="${item.id}">-</button>
              <button type="button" data-inc="${item.id}">+</button>
            </div>
          </div>
        `,
      )
      .join('');

    const total = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);
    cartTotalNode.textContent = formatMoney(total);

    cartItemsNode.querySelectorAll('[data-inc]').forEach((button) => {
      button.addEventListener('click', () => changeQuantity(button.getAttribute('data-inc'), 1));
    });

    cartItemsNode.querySelectorAll('[data-dec]').forEach((button) => {
      button.addEventListener('click', () => changeQuantity(button.getAttribute('data-dec'), -1));
    });
  }

  function addItem(item) {
    const existing = cart.find((cartItem) => cartItem.id === item.id);
    if (existing) {
      existing.quantity += 1;
    } else {
      cart.push({ ...item, quantity: 1 });
    }

    saveCart();
    renderCart();
  }

  function changeQuantity(id, delta) {
    const item = cart.find((cartItem) => cartItem.id === id);
    if (!item) return;

    item.quantity += delta;
    cart = cart.filter((cartItem) => cartItem.quantity > 0);
    saveCart();
    renderCart();
  }

  addButtons.forEach((button) => {
    button.addEventListener('click', () => {
      addItem({
        id: button.getAttribute('data-id') || '',
        name: button.getAttribute('data-name') || '',
        price: Number(button.getAttribute('data-price') || 0),
      });
    });
  });

  checkoutForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!orderStatus || !(checkoutForm instanceof HTMLFormElement)) return;

    if (!cart.length) {
      orderStatus.textContent = 'Añade algún producto antes de enviar la comanda.';
      return;
    }

    const formData = new FormData(checkoutForm);
    const payload = {
      customer: {
        name: String(formData.get('name') || ''),
        phone: String(formData.get('phone') || ''),
        service: String(formData.get('service') || 'pickup'),
        time: String(formData.get('time') || ''),
        notes: String(formData.get('notes') || ''),
      },
      items: cart.map((item) => ({
        id: item.id,
        quantity: item.quantity,
      })),
    };

    orderStatus.textContent = 'Enviando comanda al servidor local...';
    if (submitOrderButton instanceof HTMLButtonElement) {
      submitOrderButton.disabled = true;
      submitOrderButton.textContent = 'Enviando';
    }

    try {
      const response = await fetch('/api/orders', {
        method: 'POST',
        headers: {
          'content-type': 'application/json',
        },
        body: JSON.stringify(payload),
      });
      const result = await response.json();

      if (!response.ok) {
        throw new Error(result.error || 'No se pudo enviar el pedido.');
      }

      cart = [];
      saveCart();
      renderCart();
      checkoutForm.reset();
      orderStatus.textContent = `Comanda recibida por cocina: ${result.order.id}.`;
    } catch (error) {
      orderStatus.textContent = error instanceof Error ? error.message : 'No se pudo enviar el pedido.';
    } finally {
      if (submitOrderButton instanceof HTMLButtonElement) {
        submitOrderButton.disabled = false;
        submitOrderButton.textContent = 'Enviar comanda';
      }
    }
  });

  loadCart();
  renderCart();
</script>

<style>
  .takeaway-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(21rem, 0.42fr);
    gap: clamp(1.25rem, 4vw, 3rem);
    align-items: start;
  }

  .order-list {
    display: grid;
    gap: 0.85rem;
  }

  .extras-title {
    margin-top: clamp(2.5rem, 5vw, 4rem);
  }

  .order-item {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    padding: 1rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.11), rgba(255, 255, 255, 0.028)),
      radial-gradient(circle at 8% 0%, rgba(255, 157, 37, 0.12), transparent 10rem),
      rgba(11, 9, 7, 0.82);
    box-shadow: 0 1.2rem 2.5rem rgba(0, 0, 0, 0.28);
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .order-item::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent, rgba(255, 207, 106, 0.12), transparent 42%);
    opacity: 0;
    transform: translateX(-40%);
    transition: opacity 180ms ease, transform 420ms ease;
    pointer-events: none;
  }

  .order-item:hover {
    transform: translateY(-0.22rem);
    border-color: rgba(255, 207, 106, 0.32);
    box-shadow: 0 1.8rem 3.4rem rgba(0, 0, 0, 0.38), 0 0 2rem rgba(255, 77, 18, 0.12);
  }

  .order-item:hover::before {
    opacity: 1;
    transform: translateX(38%);
  }

  .order-item span {
    color: rgba(255, 188, 98, 0.68);
    font-size: 0.7rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .order-item h3 {
    margin: 0.35rem 0 0.5rem;
    font-size: clamp(1.4rem, 2.6vw, 2.4rem);
    font-weight: 1000;
    line-height: 0.92;
    text-transform: uppercase;
  }

  .order-item p,
  .order-item small {
    margin: 0;
    color: rgba(255, 255, 255, 0.66);
    line-height: 1.45;
  }

  .order-item small {
    display: block;
    margin-top: 0.7rem;
    color: rgba(255, 255, 255, 0.42);
  }

  .order-item-action {
    display: grid;
    gap: 0.75rem;
    align-content: center;
    justify-items: end;
  }

  .order-item-action strong {
    color: #ffbc62;
    font-size: 1.05rem;
  }

  .order-item-action button,
  .checkout-form button,
  .cart-controls button {
    border: 1px solid rgba(255, 157, 37, 0.5);
    border-radius: 8px;
    color: #140b04;
    background:
      linear-gradient(180deg, #ffc05f, #ff8a16 58%, #df4a11),
      #ff9d25;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.38), 0 0.85rem 1.8rem rgba(255, 75, 15, 0.22);
    cursor: pointer;
    font: inherit;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: transform 160ms ease, box-shadow 160ms ease, filter 160ms ease;
  }

  .order-item-action button:hover,
  .checkout-form button:hover,
  .cart-controls button:hover {
    transform: translateY(-1px);
    filter: saturate(1.12) brightness(1.05);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.48), 0 1rem 2.2rem rgba(255, 75, 15, 0.32);
  }

  .checkout-form button:disabled {
    cursor: wait;
    opacity: 0.7;
    transform: none;
  }

  .order-item-action button {
    min-height: 2.6rem;
    padding: 0 0.9rem;
  }

  .cart-panel {
    position: sticky;
    top: 1rem;
    padding: 1rem;
    overflow: hidden;
    border: 1px solid rgba(255, 207, 106, 0.32);
    border-radius: 8px;
    background:
      radial-gradient(circle at 50% 0%, rgba(255, 207, 106, 0.16), transparent 14rem),
      radial-gradient(circle at 90% 100%, rgba(217, 37, 22, 0.18), transparent 12rem),
      rgba(9, 7, 5, 0.92);
    box-shadow: 0 2rem 4rem rgba(0, 0, 0, 0.42), 0 0 2.5rem rgba(255, 80, 18, 0.12);
  }

  .cart-panel::before {
    content: "";
    position: absolute;
    left: -30%;
    right: -30%;
    top: -1px;
    height: 4px;
    background: linear-gradient(90deg, transparent, #ffcf6a, #ff4b12, #ffcf6a, transparent);
    filter: blur(1px);
    animation: cart-burn 3.2s ease-in-out infinite;
  }

  .cart-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .cart-head span {
    color: rgba(255, 255, 255, 0.54);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .cart-head strong {
    color: #ffbc62;
    font-size: 1.5rem;
  }

  .cart-items {
    display: grid;
    gap: 0.7rem;
    min-height: 4rem;
    padding: 1rem 0;
  }

  .empty-cart {
    margin: 0;
    color: rgba(255, 255, 255, 0.46);
  }

  .cart-line {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
    padding: 0.65rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.18);
  }

  .cart-line strong,
  .cart-line span {
    display: block;
  }

  .cart-line span {
    color: rgba(255, 255, 255, 0.52);
    font-size: 0.82rem;
  }

  .cart-controls {
    display: flex;
    gap: 0.35rem;
  }

  .cart-controls button {
    width: 2rem;
    height: 2rem;
  }

  .checkout-form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .checkout-form label {
    display: grid;
    gap: 0.4rem;
    color: rgba(255, 255, 255, 0.54);
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .checkout-form .full,
  .checkout-form button,
  .checkout-form small {
    grid-column: 1 / -1;
  }

  .checkout-form input,
  .checkout-form select,
  .checkout-form textarea {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    color: #fff;
    background: rgba(0, 0, 0, 0.32);
    font: inherit;
    padding: 0.75rem;
    transition: border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .checkout-form input:focus,
  .checkout-form select:focus,
  .checkout-form textarea:focus {
    outline: none;
    border-color: rgba(255, 207, 106, 0.58);
    background: rgba(0, 0, 0, 0.42);
    box-shadow: 0 0 0 3px rgba(255, 157, 37, 0.12), 0 0 1.4rem rgba(255, 75, 15, 0.16);
  }

  .checkout-form button {
    min-height: 3rem;
  }

  .checkout-form small {
    color: rgba(255, 255, 255, 0.46);
    line-height: 1.45;
  }

  @media (max-width: 900px) {
    .takeaway-layout,
    .order-item {
      grid-template-columns: 1fr;
    }

    .cart-panel {
      position: static;
    }

    .order-item-action {
      grid-template-columns: auto auto;
      justify-items: start;
      justify-content: space-between;
    }
  }

  @keyframes cart-burn {
    0%,
    100% {
      opacity: 0.45;
      transform: translateX(-10%);
    }
    50% {
      opacity: 1;
      transform: translateX(10%);
    }
  }
</style>
