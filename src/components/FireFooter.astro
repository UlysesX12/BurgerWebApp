---
// src/components/FireFooter.astro
---

<footer class="fire-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span>La Brasa Gamberra</span>
      <strong>Smash, fuego y rock and roll</strong>
      <p class="author-credit">Diseñada y desarrollada al completo por Jose Luis Cabanas · UlysesX12</p>
    </div>

    <div class="footer-grid">
      <div>
        <h2>Ven con hambre.</h2>
        <p>Nosotros ponemos la brasa, el queso cayendo y el punto gamberro.</p>
      </div>

      <nav aria-label="Enlaces de pie">
        <a href="/carta">Carta</a>
        <a href="/takeaway">Pedidos</a>
        <a href="/reservas">Reservas</a>
        <a href="/contacto">Contacto</a>
      </nav>

      <address>
        Calle Brasa 13 · Jerez de la Frontera<br />
        Jue-Dom · 20:00-00:30<br />
        <a href="tel:+34000000000">+34 000 000 000</a>
      </address>
    </div>
  </div>

  <div class="ember-bed" aria-hidden="true">
    <span class="heat-haze"></span>
    <span class="ash-glow ash-glow-1"></span>
    <span class="ash-glow ash-glow-2"></span>
    <span class="flame flame-1"></span>
    <span class="flame flame-2"></span>
    <span class="flame flame-3"></span>
    <span class="flame flame-4"></span>
    <span class="flame flame-5"></span>
    <span class="coal coal-1"></span>
    <span class="coal coal-2"></span>
    <span class="coal coal-3"></span>
    <span class="footer-spark footer-spark-1"></span>
    <span class="footer-spark footer-spark-2"></span>
    <span class="footer-spark footer-spark-3"></span>
    <span class="footer-spark footer-spark-4"></span>
  </div>
</footer>

<style>
  .fire-footer {
    position: relative;
    overflow: hidden;
    min-height: 32rem;
    padding: clamp(4rem, 9vw, 8rem) 1.25rem 9rem;
    background:
      radial-gradient(circle at 50% 100%, rgba(255, 184, 69, 0.28), transparent 16rem),
      radial-gradient(circle at 50% 100%, rgba(255, 90, 18, 0.48), transparent 28rem),
      linear-gradient(180deg, #050403, #020201 72%);
    color: #fff;
  }

  .footer-inner {
    position: relative;
    z-index: 2;
    width: min(1180px, 100%);
    margin: 0 auto;
  }

  .footer-brand {
    display: grid;
    gap: 0.4rem;
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }

  .footer-brand span {
    color: #ff9d25;
    font-size: 0.8rem;
    font-weight: 950;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .footer-brand strong {
    max-width: 900px;
    font-size: clamp(3rem, 8vw, 8rem);
    font-weight: 1000;
    line-height: 0.85;
    letter-spacing: 0;
    text-transform: uppercase;
    text-shadow: 0 0 40px rgba(255, 94, 20, 0.25);
  }

  .author-credit {
    max-width: 42rem;
    margin: 0.8rem 0 0;
    color: rgba(255, 255, 255, 0.58);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    line-height: 1.5;
    text-transform: uppercase;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(10rem, 0.45fr) minmax(13rem, 0.55fr);
    gap: clamp(1.25rem, 4vw, 3rem);
    align-items: end;
  }

  .footer-grid h2 {
    margin: 0;
    font-size: clamp(1.6rem, 3vw, 3rem);
    font-weight: 1000;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .footer-grid p,
  .footer-grid address {
    margin: 0.7rem 0 0;
    color: rgba(255, 255, 255, 0.62);
    font-style: normal;
    line-height: 1.6;
  }

  .footer-grid nav {
    display: grid;
    gap: 0.45rem;
  }

  .footer-grid a {
    color: rgba(255, 255, 255, 0.72);
    font-weight: 900;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .footer-grid a:hover {
    color: #ffbc62;
  }

  .ember-bed {
    position: absolute;
    left: -10%;
    right: -10%;
    bottom: -4rem;
    z-index: 1;
    height: 17rem;
    background:
      radial-gradient(ellipse at 50% 100%, rgba(255, 221, 121, 0.68), transparent 34%),
      radial-gradient(ellipse at 50% 82%, rgba(255, 59, 18, 0.48), transparent 58%),
      radial-gradient(ellipse at 35% 92%, rgba(255, 118, 27, 0.42), transparent 32%),
      radial-gradient(ellipse at 70% 90%, rgba(196, 28, 12, 0.45), transparent 36%),
      linear-gradient(180deg, transparent, rgba(255, 72, 14, 0.18));
    filter: saturate(1.35) contrast(1.08);
  }

  .ember-bed::before,
  .ember-bed::after {
    content: "";
    position: absolute;
    left: 8%;
    right: 8%;
    bottom: 3.2rem;
    height: 2.2rem;
    border-radius: 50%;
    background:
      repeating-linear-gradient(90deg, rgba(33, 12, 7, 0.95) 0 2.5rem, rgba(255, 91, 18, 0.46) 2.5rem 3rem),
      radial-gradient(ellipse at center, rgba(255, 179, 67, 0.5), transparent 68%);
    filter: blur(3px);
    opacity: 0.86;
  }

  .ember-bed::after {
    bottom: 2.2rem;
    left: 18%;
    right: 14%;
    height: 1.35rem;
    opacity: 0.58;
    filter: blur(5px);
  }

  .heat-haze {
    position: absolute;
    left: 4%;
    right: 4%;
    bottom: 7rem;
    height: 12rem;
    background:
      linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.08), transparent 18%, rgba(255, 209, 119, 0.09), transparent 36%),
      radial-gradient(ellipse at 50% 100%, rgba(255, 195, 100, 0.18), transparent 68%);
    filter: blur(18px);
    mix-blend-mode: screen;
    opacity: 0.65;
    animation: heat-waver 2.8s ease-in-out infinite;
  }

  .ash-glow {
    position: absolute;
    bottom: 4.8rem;
    width: 20rem;
    height: 4rem;
    border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(255, 198, 96, 0.46), rgba(255, 75, 16, 0.24) 46%, transparent 72%);
    filter: blur(9px);
    mix-blend-mode: screen;
    animation: ash-pulse 2.4s ease-in-out infinite;
  }

  .ash-glow-1 { left: 18%; }
  .ash-glow-2 { right: 18%; animation-delay: -1.2s; }

  .flame {
    position: absolute;
    bottom: 3.4rem;
    width: 5rem;
    height: 11rem;
    border-radius: 52% 48% 45% 55%;
    background:
      radial-gradient(ellipse at 50% 72%, rgba(255, 247, 190, 0.92), transparent 27%),
      radial-gradient(ellipse at 46% 50%, rgba(255, 151, 28, 0.86), transparent 54%),
      radial-gradient(ellipse at 58% 72%, rgba(213, 30, 10, 0.74), transparent 72%);
    filter: blur(1.6px) saturate(1.18);
    mix-blend-mode: screen;
    transform-origin: bottom;
    animation: flame-dance 1.8s ease-in-out infinite;
  }

  .flame-1 { left: 16%; height: 8rem; animation-delay: -0.4s; }
  .flame-2 { left: 32%; width: 7rem; height: 13rem; animation-delay: -1.1s; }
  .flame-3 { left: 49%; height: 10rem; animation-delay: -0.8s; }
  .flame-4 { right: 28%; width: 6rem; height: 12rem; animation-delay: -1.4s; }
  .flame-5 { right: 13%; height: 8.5rem; animation-delay: -0.2s; }

  .coal {
    position: absolute;
    bottom: 4rem;
    width: 16rem;
    height: 2.8rem;
    border-radius: 50%;
    background: radial-gradient(ellipse at center, rgba(255, 83, 22, 0.72), rgba(74, 14, 8, 0.5) 54%, transparent 72%);
    filter: blur(4px);
  }

  .coal-1 { left: 20%; }
  .coal-2 { left: 45%; }
  .coal-3 { right: 12%; }

  .footer-spark {
    position: absolute;
    bottom: 7rem;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #ffbc62;
    box-shadow: 0 0 18px 4px rgba(255, 94, 20, 0.68);
    animation: footer-spark 4s linear infinite;
  }

  .footer-spark-1 { left: 22%; animation-delay: -0.8s; }
  .footer-spark-2 { left: 38%; animation-delay: -2.4s; }
  .footer-spark-3 { right: 36%; animation-delay: -1.6s; }
  .footer-spark-4 { right: 19%; animation-delay: -3.2s; }

  @keyframes flame-dance {
    0%,
    100% {
      opacity: 0.62;
      transform: scaleX(0.9) scaleY(0.92) rotate(-4deg);
    }
    50% {
      opacity: 0.96;
      transform: scaleX(1.1) scaleY(1.08) rotate(5deg);
    }
  }

  @keyframes heat-waver {
    0%,
    100% {
      opacity: 0.42;
      transform: translateX(-1.4rem) skewX(-8deg);
    }
    50% {
      opacity: 0.78;
      transform: translateX(1.2rem) skewX(7deg);
    }
  }

  @keyframes ash-pulse {
    0%,
    100% {
      opacity: 0.34;
      transform: scaleX(0.92);
    }
    50% {
      opacity: 0.74;
      transform: scaleX(1.12);
    }
  }

  @keyframes footer-spark {
    0% {
      opacity: 0;
      transform: translate3d(0, 0, 0) scale(0.4);
    }
    14% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translate3d(2.5rem, -18rem, 0) scale(1.1);
    }
  }

  @media (max-width: 760px) {
    .footer-grid {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .fire-footer {
      padding-bottom: 8rem;
    }

    .flame {
      transform: scale(0.78);
    }
  }
</style>
