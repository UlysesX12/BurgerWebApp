---
import burgerPoster from '../assets/Image2.png';

interface Props {
  kicker: string;
  title: string;
  description: string;
}

const { kicker, title, description } = Astro.props;
---

<main class="page-frame" style={`--page-poster: url("${burgerPoster.src}")`}>
  <section class="page-hero">
    <div class="page-bg" aria-hidden="true"></div>
    <div class="page-ring" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <div class="page-hero-inner">
      <p>{kicker}</p>
      <h1>{title}</h1>
      <span>{description}</span>
    </div>
  </section>

  <slot />
</main>

<style>
  .page-frame {
    min-height: 100vh;
    overflow-x: hidden;
    background:
      radial-gradient(circle at 50% 0%, rgba(255, 207, 106, 0.2), transparent 22rem),
      radial-gradient(circle at 18% 24%, rgba(217, 37, 22, 0.16), transparent 26rem),
      linear-gradient(180deg, #050403, #090604 42%, #030201);
    color: #fff;
  }

  .page-hero {
    position: relative;
    display: grid;
    min-height: 66vh;
    place-items: end start;
    overflow: hidden;
    padding: clamp(7.5rem, 14vh, 11rem) 1.25rem clamp(3.5rem, 8vw, 6.5rem);
  }

  .page-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image:
      radial-gradient(circle at 50% 54%, transparent 0 18rem, rgba(0, 0, 0, 0.34) 28rem),
      linear-gradient(90deg, rgba(0, 0, 0, 0.88), transparent 46%, rgba(0, 0, 0, 0.76)),
      linear-gradient(180deg, rgba(0, 0, 0, 0.15), #050403 94%),
      var(--page-poster);
    background-position: center;
    background-size: cover;
    filter: saturate(1.18) contrast(1.12);
    transform: scale(1.03);
  }

  .page-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.028) 1px, transparent 1px);
    background-size: 70px 70px;
    opacity: 0.22;
  }

  .page-bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 22%, rgba(255, 210, 106, 0.22), transparent 14rem),
      radial-gradient(circle at 74% 18%, rgba(255, 74, 18, 0.2), transparent 16rem),
      linear-gradient(120deg, transparent 18%, rgba(255, 255, 255, 0.08), transparent 34%);
    mix-blend-mode: screen;
    animation: page-light-pulse 5s ease-in-out infinite;
  }

  .page-ring {
    position: absolute;
    inset: auto 0 0;
    z-index: 1;
    height: 18rem;
    pointer-events: none;
  }

  .page-ring span {
    position: absolute;
    left: 50%;
    bottom: -5rem;
    width: min(86rem, 125vw);
    height: 12rem;
    border: 1px solid rgba(255, 157, 37, 0.24);
    border-radius: 50%;
    box-shadow: 0 0 2rem rgba(255, 83, 18, 0.18), inset 0 0 2rem rgba(255, 196, 91, 0.08);
    transform: translateX(-50%) rotate(-2deg);
  }

  .page-ring span:nth-child(2) {
    bottom: -2.8rem;
    width: min(72rem, 112vw);
    opacity: 0.64;
    transform: translateX(-50%) rotate(2deg);
  }

  .page-ring span:nth-child(3) {
    bottom: -0.9rem;
    width: min(58rem, 98vw);
    opacity: 0.42;
  }

  .page-hero-inner {
    position: relative;
    z-index: 1;
    width: min(1180px, 100%);
    margin: 0 auto;
  }

  .page-hero p {
    margin: 0 0 0.75rem;
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0 0.72rem;
    border: 1px solid rgba(255, 207, 106, 0.32);
    border-radius: 999px;
    color: #ffcf6a;
    background: rgba(255, 157, 37, 0.08);
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    box-shadow: 0 0 1.7rem rgba(255, 91, 18, 0.16);
  }

  .page-hero h1 {
    max-width: 980px;
    margin: 0;
    font-size: clamp(3.8rem, 9.6vw, 10.6rem);
    font-weight: 1000;
    line-height: 0.78;
    letter-spacing: 0;
    text-transform: uppercase;
    text-shadow:
      0 0 34px rgba(0, 0, 0, 0.9),
      0 0 44px rgba(255, 83, 18, 0.22),
      0 8px 0 rgba(0, 0, 0, 0.52);
  }

  .page-hero span {
    display: block;
    max-width: 42rem;
    margin-top: 1.1rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    line-height: 1.55;
  }

  :global(.content-section) {
    width: min(1180px, calc(100% - 2.5rem));
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 6rem) 0;
  }

  :global(.section-title) {
    margin: 0 0 1.5rem;
    font-size: clamp(2rem, 5vw, 5rem);
    font-weight: 1000;
    line-height: 0.9;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  :global(.card-grid) {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  :global(.brasa-card) {
    position: relative;
    min-height: 15rem;
    padding: 1.2rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.025)),
      radial-gradient(circle at 18% 0%, rgba(255, 157, 37, 0.14), transparent 12rem),
      rgba(13, 11, 9, 0.82);
    box-shadow: 0 1.6rem 3.4rem rgba(0, 0, 0, 0.34), inset 0 1px 0 rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(14px);
    transition: transform 200ms ease, border-color 200ms ease, box-shadow 200ms ease;
  }

  :global(.brasa-card::before) {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(120deg, transparent, rgba(255, 210, 106, 0.12), transparent 42%);
    opacity: 0;
    pointer-events: none;
    transform: translateX(-45%);
    transition: opacity 200ms ease, transform 420ms ease;
  }

  :global(.brasa-card:hover) {
    transform: translateY(-0.32rem);
    border-color: rgba(255, 207, 106, 0.32);
    box-shadow: 0 2rem 4rem rgba(0, 0, 0, 0.42), 0 0 2.4rem rgba(255, 79, 18, 0.14);
  }

  :global(.brasa-card:hover::before) {
    opacity: 1;
    transform: translateX(35%);
  }

  :global(.brasa-card h2),
  :global(.brasa-card h3) {
    margin: 0 0 0.8rem;
    font-size: clamp(1.55rem, 3vw, 2.6rem);
    font-weight: 1000;
    line-height: 0.92;
    text-transform: uppercase;
  }

  :global(.brasa-card p) {
    margin: 0;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.55;
  }

  :global(.brasa-card strong) {
    display: block;
    margin-top: 1.2rem;
    color: #ffbc62;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  :global(.action-link) {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    margin-top: 1.5rem;
    padding: 0 1.1rem;
    border: 1px solid rgba(255, 157, 37, 0.56);
    border-radius: 8px;
    color: #140b04;
    background:
      linear-gradient(180deg, #ffc05f, #ff8a16 58%, #df4a11),
      #ff9d25;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35), 0 0.85rem 1.8rem rgba(255, 75, 15, 0.22);
    font-size: 0.84rem;
    font-weight: 950;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    transition: transform 160ms ease, box-shadow 160ms ease, filter 160ms ease;
  }

  :global(.action-link:hover) {
    transform: translateY(-1px);
    filter: saturate(1.12) brightness(1.05);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.46), 0 1rem 2.2rem rgba(255, 75, 15, 0.32);
  }

  @keyframes page-light-pulse {
    0%,
    100% {
      opacity: 0.48;
      transform: translateX(-1rem);
    }
    50% {
      opacity: 0.88;
      transform: translateX(1rem);
    }
  }

  @media (max-width: 760px) {
    :global(.card-grid) {
      grid-template-columns: 1fr;
    }

    .page-hero {
      min-height: 58vh;
      padding-top: 6.5rem;
    }
  }
</style>
